# Copy this to `.env` and fill in the values.

# Anthropic API key — from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# These are printed by `python setup.py`. Save them here after the first run.
HUMANIZER_ENV_ID=env_...
HUMANIZER_AGENT_ID=agent_...
HUMANIZER_AGENT_VERSION=

# Optional — override the environment name on setup
# HUMANIZER_ENV_NAME=humanizer-env
